# ─── Server ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
# Comma-separated list of allowed CORS origins (the Next.js frontend)
CORS_ORIGINS=http://localhost:3000

# ─── Database (Supabase Postgres) ────────────────────────────────────────────
# Pooled connection (PgBouncer, port 6543) — used by the app at runtime.
# Append ?pgbouncer=true&connection_limit=1 for Prisma + PgBouncer.
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct connection (port 5432) — used by `prisma migrate` only.
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# ─── Auth / JWT ──────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_ACCESS_TTL=900            # seconds (15m)
JWT_REFRESH_TTL=2592000       # seconds (30d)
AUTH_NONCE_TTL=300            # seconds (5m) — SIWS challenge validity

# ─── Game ────────────────────────────────────────────────────────────────────
# 360 = dev/demo speed (1h growth -> 10s). Set to 1 for real-time (prod).
DEV_TIME_SCALE=360

# ─── Solana (Phase 11 — leave blank until then) ──────────────────────────────
SOLANA_CLUSTER=devnet
SOLANA_RPC_URL=
BLOOM_MINT_ADDRESS=
# Path or base58 of the treasury/mint authority keypair (NEVER commit real keys).
TREASURY_KEYPAIR=
MERKLE_TREE_ADDRESS=

# ─── Faucet (dev/testing) ────────────────────────────────────────────────────
# Mints free $BLOOM to a player's wallet, claimable repeatedly. Set to false in
# prod to disable without a code change (enabled unless explicitly false/0).
FAUCET_ENABLED=true
FAUCET_AMOUNT=1000

# ─── NFT passive income (yield) ──────────────────────────────────────────────
# Held cNFTs accrue $BLOOM, claimed on demand. Per-NFT hourly yield =
# YIELD_BASE_PER_HOUR × the NFT's rarity multiplier (10 × Diamond 100 = 1000/hr).
# Set YIELD_ENABLED=false in prod to disable without a code change.
YIELD_ENABLED=true
YIELD_BASE_PER_HOUR=10
YIELD_MIN_CLAIM=1
# DAS-capable RPC (Helius/Triton) for getAssetsByOwner — verifies current
# ownership before paying. Public cluster RPC does NOT support DAS. e.g.
# https://devnet.helius-rpc.com/?api-key=YOUR_KEY
DAS_RPC_URL=

PUBLIC_BASE_URL=http://localhost:4000
